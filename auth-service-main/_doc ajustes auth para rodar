criar o docker do banco

docker run -d \
  --name postgres-auth \
  --network togglemaster-net \
  -e POSTGRES_USER=admin \
  -e POSTGRES_PASSWORD=123 \
  -e POSTGRES_DB=auth_db \
  -p 5432:5432 \
  postgres:16

criar a tabela

docker exec -i postgres-auth \
psql -U admin -d auth_db < auth-service-main/db/init.sql

entrar no banco

docker exec -it postgres-auth psql -U admin -d auth_db

